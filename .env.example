# Exchange Configuration
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_TESTNET=true

# Risk Management
MAX_POSITION_SIZE_PCT=0.1
MAX_DAILY_LOSS_PCT=0.03
RISK_PER_TRADE_PCT=0.01

# Database
DATABASE_URL=postgresql://localhost:5432/trading_system
REDIS_URL=redis://localhost:6379

# Telegram Alerts (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API Security (opcional)
# Generate with: openssl rand -base64 32
# If not set, API authentication will be disabled
JWT_SECRET=

# Server
PORT=3000
WEBHOOK_SECRET=change_this_to_a_random_32_character_string_please

# Trading Configuration
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=5m
